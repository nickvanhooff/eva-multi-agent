# LLM Provider Configuration
# Supported: ollama, openrouter, groq
LLM_PROVIDER=groq

# Model name (provider-specific)
LLM_MODEL=llama-3.3-70b-versatile

# API base URL
# Ollama:      http://localhost:11434/v1
# OpenRouter:  https://openrouter.ai/api/v1
# Groq:        https://api.groq.com/openai/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# API key (not needed for Ollama)
LLM_API_KEY=your_api_key_here

LangSmith Configuration (optional, for debugging & monitoring)
Get API key from: https://smith.langchain.com
To enable: uncomment the lines below and fill in your API key

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls_your_api_key_here
LANGSMITH_PROJECT=eva-marketing-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
